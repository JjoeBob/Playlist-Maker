<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/mainScreenBackground"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/standard_padding">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="40dp"
        android:fontFamily="@font/ys_display_medium"
        android:text="@string/app_name"
        android:textColor="@color/yp_white"
        android:textFontWeight="500"
        android:textSize="@dimen/text_size_large" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/main_search_button"
        style="@style/MenuButton"
        android:layout_marginBottom="@dimen/standard_padding"
        android:text="@string/button_search"
        app:icon="@drawable/ic_search_24" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/main_library_button"
        style="@style/MenuButton"
        android:layout_marginBottom="@dimen/standard_padding"
        android:text="@string/button_library"
        app:icon="@drawable/ic_library_24" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/main_settings_button"
        style="@style/MenuButton"
        android:layout_marginBottom="28dp"
        android:text="@string/button_settings"
        app:icon="@drawable/ic_settings_24" />

</LinearLayout>